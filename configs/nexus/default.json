{
  "search": {
    "searxng_base_url": "http://127.0.0.1:8080",
    "categories": ["general", "science", "it"],
    "language": "en-US",
    "max_results_per_intent": 5,
    "request_timeout_s": 8
  },
  "pipeline": {
    "run_id_prefix": "nexus",
    "max_search_intents": 6,
    "max_iterations": 3,
    "retrieval_chunk_size": 900,
    "retrieval_top_k": 12,
    "cache_ttl_s": 3600,
    "strict_citation_required": true,
    "dry_run": true
  },
  "runtime": {
    "artifacts_dir": "artifacts/nexus",
    "retry_attempts": 2,
    "retry_backoff_s": 0.5,
    "stage_timeout_s": 120
  },
  "router_rules": [
    {"task": "router", "preferred_model": "nemotron-4b-local", "fallback_models": ["nemotron-3-nano-30b"]},
    {"task": "reason", "preferred_model": "nemotron-cascade-2-30b", "fallback_models": ["nemotron-3-nano-30b"]},
    {"task": "critique", "preferred_model": "nemotron-3-nano-30b", "fallback_models": ["qwen3.5-35b-a3b-q8_0"]},
    {"task": "synthesize", "preferred_model": "nemotron-3-super-latest", "fallback_models": ["nemotron-cascade-2-30b"]}
  ],
  "model_profiles": [
