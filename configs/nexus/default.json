    {"name": "qwen3-embedding-4b-fp16", "endpoint": "http://192.168.1.40:11434/api/embeddings", "max_context_tokens": 32768, "temperature": 0.0, "max_output_tokens": 1, "timeout_s": 20, "role": "embedding/index"},
    {"name": "nemotron-cascade-2-30b", "endpoint": "http://192.168.1.40:11434/v1/chat/completions", "max_context_tokens": 32768, "temperature": 0.2, "max_output_tokens": 1200, "timeout_s": 45, "role": "primary research reasoner"},
    {"name": "qwen3-coder-30b-a3b-q8_0", "endpoint": "http://192.168.1.41:11434/v1/chat/completions", "max_context_tokens": 32768, "temperature": 0.1, "max_output_tokens": 1400, "timeout_s": 45, "role": "code agent/toolmaker"},
    {"name": "nemotron-3-nano-30b", "endpoint": "http://192.168.1.42:11434/v1/chat/completions", "max_context_tokens": 16384, "temperature": 0.2, "max_output_tokens": 900, "timeout_s": 30, "role": "fast secondary analyst"},
    {"name": "nemotron-3-super-latest", "endpoint": "http://192.168.1.43:11434/v1/chat/completions", "max_context_tokens": 65536, "temperature": 0.2, "max_output_tokens": 1500, "timeout_s": 80, "role": "board reviewer"},
