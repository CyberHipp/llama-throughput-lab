{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llama-throughput-lab/schemas/nexus_receipt_v1.json",
  "title": "NEXUS Receipt v1",
  "type": "object",
  "required": [
    "RUN_ID",
    "TIMESTAMP_UTC",
    "INTENT",
    "TOOL_NAME",
    "PINNED_COMMIT",
    "resolved_command",
    "resolved_endpoint_path",
    "resolved_request_payload",
    "resolved_topology",
    "resolved_model_path",
    "resolved_llama_server_path",
    "resolved_runtime_env",
    "verification_mode",
    "expected_text",
    "verification_result",
    "failure_summary",
    "next_step",
    "receipt_artifact_path",
    "stdout_artifact_path",
    "stderr_artifact_path",
    "exit_code_artifact_path"
  ],
  "properties": {
    "RUN_ID": {"type": "string"},
    "TIMESTAMP_UTC": {"type": "string"},
    "INTENT": {"type": "string"},
    "TOOL_NAME": {"type": "string"},
    "PINNED_COMMIT": {"type": "string"},
    "resolved_command": {"type": "array"},
    "resolved_endpoint_path": {"type": ["string", "null"]},
    "resolved_request_payload": {"type": "object"},
    "resolved_topology": {"type": "string"},
    "resolved_model_path": {"type": "string"},
    "resolved_llama_server_path": {"type": "string"},
    "resolved_runtime_env": {"type": "object"},
    "verification_mode": {"type": "string"},
    "expected_text": {"type": ["string", "null"]},
    "verification_result": {"type": "string", "enum": ["pass", "fail"]},
    "failure_summary": {"type": "string"},
    "next_step": {"type": "string"},
    "receipt_artifact_path": {"type": "string"},
    "stdout_artifact_path": {"type": "string"},
    "stderr_artifact_path": {"type": "string"},
    "exit_code_artifact_path": {"type": "string"}
  },
  "additionalProperties": true
}
